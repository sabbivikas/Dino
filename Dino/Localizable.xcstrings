    "this will delete all your moods, journals and gratitude. are you sure?": {
      "extractionState": "manual",
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "esto eliminará todos tus ánimos, diarios y gratitud. ¿estás seguro?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "気分、日記、感謝の記録がすべて削除されるよ。本当にいい？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기분, 일기, 감사 기록이 모두 삭제돼요. 정말 진행할까요?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "mọi tâm trạng, nhật ký và lòng biết ơn sẽ bị xóa. bạn chắc chứ?"
          }
        }
      },
      "shouldGenerateSymbol": false
    },
    "this will permanently delete your account, all your data from the cloud, and sign you out. this cannot be undone. are you sure?": {
      "extractionState": "manual",
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "esto eliminará permanentemente tu cuenta, todos tus datos de la nube, y cerrará tu sesión. no se puede deshacer. ¿estás seguro?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントとクラウド上のすべてのデータが完全に削除されて、サインアウトされるよ。元に戻せないけど、本当にいい？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정과 클라우드의 모든 데이터가 영구 삭제되고 로그아웃돼요. 되돌릴 수 없어요. 정말 진행할까요?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "tài khoản và toàn bộ dữ liệu trên đám mây sẽ bị xóa vĩnh viễn và bạn sẽ bị đăng xuất. không thể hoàn tác. bạn chắc chứ?"
          }
        }
      },
      "shouldGenerateSymbol": false
    },
