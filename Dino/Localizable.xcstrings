    "dino couldn't carry this one 🦕 lanterns only travel when they're gentle. want to rewrite it?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "dino couldn't carry this one 🦕 lanterns only travel when they're gentle. want to rewrite it?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "dino no pudo llevar este 🦕 los farolillos solo viajan cuando son amables. ¿quieres reescribirlo?"
