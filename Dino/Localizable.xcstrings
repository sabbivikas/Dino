            "value": "haven't heard your voice in a day — even one breath counts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "llevo un día sin oír tu voz. hasta una respiración cuenta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一日、あなたの声を聞いてないな。ひと呼吸だけでもいいんだよ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "하루 동안 당신 목소리를 못 들었어요. 숨 한 번도 충분해요."
