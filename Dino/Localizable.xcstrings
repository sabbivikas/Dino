    "4 minutes of breathing activates your body's calm response. dino will guide you through it.": {
      "extractionState": "manual",
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "4 minutos de respiración activan la respuesta de calma de tu cuerpo. dino te guiará."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "4分の呼吸で、からだの落ち着く反応が動きだすよ。ディノが案内するね。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "4분의 호흡이 몸의 안정 반응을 깨워요. 디노가 함께할게요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "4 phút hít thở đánh thức phản ứng thư giãn của cơ thể. dino sẽ dẫn bạn từng bước."
          }
        }
      },
      "shouldGenerateSymbol": false
    },
