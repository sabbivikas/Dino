    "dino sometimes goes looking for small things for you, using only your weather patterns, never your words.": {
      "extractionState": "manual",
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "a veces dino sale a buscar cositas para ti, usando solo tus patrones de clima, nunca tus palabras."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディノはときどき、あなたのために小さなものを探しにいくよ。使うのはこころの天気の模様だけ。あなたの言葉は決して使わない。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디노는 가끔 당신을 위해 작은 것들을 찾으러 가요. 마음 날씨의 무늬만 쓰고, 당신의 말은 절대 쓰지 않아요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "thỉnh thoảng dino đi tìm những món nhỏ cho bạn, chỉ dùng nhịp thời tiết trong lòng bạn, không bao giờ dùng lời của bạn."
          }
        }
      },
      "shouldGenerateSymbol": false
    },
