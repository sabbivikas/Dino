        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "준비가 되면, 부드러운 호흡이 여기 있어요. 서두르지 않아도 돼요. 기다리고 있을게요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
