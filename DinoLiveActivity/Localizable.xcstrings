    "A calming affirmation that changes every day to ground and inspire you.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A calming affirmation that changes every day to ground and inspire you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "una afirmación calmante que cambia cada día para centrarte e inspirarte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "毎日かわる、こころを落ちつけてくれるアファメーション。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "매일 바뀌며 마음을 다잡아주는 확언이에요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "một lời khẳng định dịu êm, đổi mới mỗi ngày để giúp bạn vững vàng và có cảm hứng."
          }
        }
      },
      "shouldGenerateSymbol": false
    },
