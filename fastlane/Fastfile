default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # App Store Connect API key — avoids 2FA and lets xcodebuild manage signing
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      in_house:    false
    )

    # Bump build number to current timestamp so each upload is unique
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
    )

    # Build archive — xcodebuild handles signing automatically via the API key
    build_app(
      scheme:             "Dino",
      project:            "Dino.xcodeproj",
      configuration:      "Release",
      export_method:      "app-store",
      xcargs:             "DEVELOPMENT_TEAM=BA9NL64C62 CODE_SIGN_STYLE=Automatic -allowProvisioningUpdates",
      output_directory:   "build",
      output_name:        "Dino.ipa",
      clean:              true
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key:                          api_key,
      skip_waiting_for_build_processing: true,
      distribute_external:              false
    )
  end
end
