rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    match /painting_quota/{uid}/days/{day} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /emailQueue/{docId} {
      allow read, write: if false;
    }

    // DINO WORLD — anonymous global mood map.
    // Clients may only CREATE strictly-shaped anonymous docs (no UID stored;
    // auth is required purely as an abuse gate). Nobody but the aggregation
    // function (admin SDK) can read the raw collection.
    match /worldMoods/{docId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['mood', 'countryCode', 'dayKey', 'createdAt', 'expiresAt'])
        && request.resource.data.mood in ['clear', 'partlyCloudy', 'overwhelmed', 'drained']
        && request.resource.data.countryCode is string
        && request.resource.data.countryCode.size() >= 2
        && request.resource.data.countryCode.size() <= 9
        && request.resource.data.dayKey is string
        && request.resource.data.dayKey.size() == 10
        && request.resource.data.createdAt == request.time
        && request.resource.data.expiresAt is timestamp;
      allow read, update, delete: if false;
    }

    // The hourly aggregate (per-country counts, below-floor days folded into
    // "elsewhere"). Read-only for signed-in clients; only the cloud function
    // writes it.
    match /worldAggregate/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Live pulses — short-TTL anonymous blooms written ONLY by the
    // onWorldMoodCreated trigger (admin SDK). Open globes listen; clients
    // can never write one directly.
    match /worldPulses/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // LANTERNS — the pool and claim ledger are server-only (cloud functions via
    // admin SDK). Clients never touch them directly: sending goes through
    // moderateLantern, receiving through claimLantern.
    match /lanterns/{docId} {
      allow read, write: if false;
    }
    match /lanternClaims/{uid} {
      allow read, write: if false;
    }
    match /lanternLimits/{uid} {
      allow read, write: if false;
    }

    // DINO EXPEDITIONS — the client writes ONLY its own enum-bucket signal
    // doc (strict shape: booleans and allowlisted bucket strings, no free
    // text, no numbers). The expedition result doc is server-written only.
    match /expeditionSignals/{uid} {
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['eligible','moodTrend','heavyDays7','themes','sleepBucket','stepsBucket','sinceLastRec','sinceLastExpedition','updatedAt'])
        && request.resource.data.eligible is bool
        && request.resource.data.moodTrend in ['steady','wobbly','heavy']
        && request.resource.data.heavyDays7 in ['0','1','2to3','4plus']
        && request.resource.data.sleepBucket in ['unknown','short','ok','long']
        && request.resource.data.stepsBucket in ['unknown','low','mid','high']
        && request.resource.data.sinceLastRec in ['0to2','3to7','8to13','14plus']
        && request.resource.data.sinceLastExpedition in ['0to2','3to7','8to13','14plus']
        && request.resource.data.themes is list
        && request.resource.data.themes.size() <= 3
        && request.resource.data.updatedAt == request.time;
      allow read: if request.auth != null && request.auth.uid == uid;
    }
    match /expeditions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Outcome ledger (memory + shelf arc F1) — the enum twin of the shelf.
    // Enum-shaped ONLY; the single string field is a gift's publisher domain
    // (server trusted-sources vocabulary), size-capped. Content never lands here.
    match /outcomes/{uid}/entries/{entryId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['kind','itemType','sourceDomain','moodContext','daypart','action','needsFollowup','shownAt','expiresAt'])
        && request.resource.data.kind in ['rec','gift']
        && ((request.resource.data.kind == 'rec'
              && request.resource.data.itemType in ['music','book','film']
              && !request.resource.data.keys().hasAny(['sourceDomain']))
            || (request.resource.data.kind == 'gift'
              && request.resource.data.itemType in ['rest','beauty','hope','wonder','connection']
              && (!request.resource.data.keys().hasAny(['sourceDomain'])
                  || (request.resource.data.sourceDomain is string
                      && request.resource.data.sourceDomain.size() <= 40))))
        && request.resource.data.moodContext in ['clear','partlyCloudy','overwhelmed','drained','none']
        && request.resource.data.daypart in ['morning','afternoon','evening','night']
        && request.resource.data.action == 'shown'
        && request.resource.data.needsFollowup == true
        && request.resource.data.shownAt == request.time
        && request.resource.data.expiresAt is timestamp;
      allow update: if request.auth != null && request.auth.uid == uid
        && (
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['action','actionAt'])
            && request.resource.data.action in ['opened','kept','ignored','notTonight','lateKept']
            && request.resource.data.actionAt == request.time)
          ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followupTrend','followupAt','needsFollowup'])
            && request.resource.data.followupTrend in ['improved','steady','heavier','unknown']
            && request.resource.data.followupAt == request.time
            && request.resource.data.needsFollowup == false)
        );
      allow delete: if false;
    }

    // Preference doc (F2) — derived, server-write-only, client reads own.
    match /prefs/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Received-lantern reports: create-only, strict shape, for manual review.
    match /lanternReports/{docId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['text', 'countryCode', 'receivedAt', 'createdAt', 'reporterUid'])
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 200
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
